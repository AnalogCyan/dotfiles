{
  "$schema": "https://aka.ms/winget-settings.schema.json",

  "source": {
    "autoUpdateIntervalInMinutes": 15
  },

  "visual": {
    "progressBar": "rainbow"
  },

  "installBehavior": {
    "skipDependencies": false,
    "disableInstallNotes": true,
    "archiveExtractionMethod": "tar"
  },

  "experimentalFeatures": {
    "dependencies": true,
    "directMSI": true,
    "zipInstall": true
  }
}
