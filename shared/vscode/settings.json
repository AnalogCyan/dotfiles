{
  // ──────────────────────────────
  // Window / Workbench
  // ──────────────────────────────
  "window.restoreWindows": "none",
  "window.commandCenter": true,
  "window.titleBarStyle": "custom",
  "window.newWindowDimensions": "inherit",
  "workbench.productIconTheme": "fluent-icons",
  "workbench.iconTheme": "Monokai Pro (Filter Ristretto) Icons",
  "workbench.startupEditor": "none",
  "workbench.editor.tabActionLocation": "left",
  "workbench.colorTheme": "Monokai Pro (Filter Ristretto)",
  "workbench.list.smoothScrolling": true,
  "workbench.editor.empty.hint": "hidden",

  // ──────────────────────────────
  // Editor (global)
  // ──────────────────────────────
  "editor.guides.bracketPairs": "active",
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.formatOnType": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "always",
    "source.fixAll": "always",
  },
  "editor.foldingImportsByDefault": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.stickyScroll.enabled": true,
  "editor.fontFamily": "'MonaspiceAr NF', Menlo, Monaco, 'Droid Sans Mono', 'Courier New', monospace",
  "editor.fontSize": 13,
  "editor.fontLigatures": true,
  "editor.tabSize": 2,
  "editor.inlineSuggest.enabled": true,
  "editor.inlineSuggest.fontFamily": "'MonaspiceKr NF'",
  "editor.bracketPairColorization.independentColorPoolPerBracketType": true,
  "editor.linkedEditing": true,
  "editor.smoothScrolling": true,
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.wordWrap": "off",
  "editor.scrollBeyondLastColumn": 5,
  "editor.scrollbar.horizontal": "auto",

  // ──────────────────────────────
  // Explorer
  // ──────────────────────────────
  "explorer.incrementalNaming": "smart",
  "explorer.confirmDragAndDrop": false,
  "explorer.excludeGitIgnore": true,

  // ──────────────────────────────
  // Files
  // ──────────────────────────────
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1500,
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.simpleDialog.enable": true,

  // ──────────────────────────────
  // Search
  // ──────────────────────────────
  "search.showLineNumbers": true,

  // ──────────────────────────────
  // Git & SCM
  // ──────────────────────────────
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "always",
  "git.autofetch": true,
  "git.ignoreRebaseWarning": true,
  "scm.diffDecorationsGutterPattern": {
    "added": true,
  },
  "scm.diffDecorationsIgnoreTrimWhitespace": "inherit",

  // ──────────────────────────────
  // Terminal
  // ──────────────────────────────
  "terminal.integrated.fontFamily": "'MonaspiceAr NF', Menlo, Monaco, 'Droid Sans Mono', 'Courier New', monospace",
  "terminal.integrated.fontLigatures": true,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorStyleInactive": "line",
  "terminal.integrated.enableImages": true,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.profiles.osx": {
    "zsh": {
      "path": "zsh",
      "args": ["--no-rcs"],
    },
  },
  "terminal.integrated.profiles.linux": {
    "zsh": {
      "path": "zsh",
      "args": ["--no-rcs"],
    },
  },
  "terminal.external.osxExec": "iTerm.app",
  "terminal.external.linuxExec": "x-terminal-emulator",

  // ──────────────────────────────
  // Languages / Extensions
  // ──────────────────────────────
  "python.languageServer": "Pylance",
  "python.terminal.activateEnvInCurrentTerminal": true,
  "python.terminal.focusAfterLaunch": true,
  "python.terminal.shellIntegration.enabled": true,
  "python.analysis.autoFormatStrings": true,
  "python.analysis.autoImportCompletions": true,
  "python.analysis.typeCheckingMode": "basic",
  "prettier.resolveGlobalModules": true,

  // ──────────────────────────────
  // GitHub / Copilot / Chat
  // ──────────────────────────────
  "githubPullRequests.createOnPublishBranch": "never",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
  },
  "github.copilot.chat.scopeSelection": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "chat.agentSessionProjection.enabled": true,
  "chat.checkpoints.showFileChanges": true,
  "chat.customAgentInSubagent.enabled": true,
  "chat.editing.explainChanges.enabled": true,
  "chat.edits2.enabled": true,
  "chat.experimental.useSkillAdherencePrompt": true,
  "chat.includeReferencedInstructions": true,
  "chat.mcp.assisted.nuget.enabled": true,
  "chat.tips.enabled": true,
  "chat.unifiedAgentsBar.enabled": true,
  "chat.viewProgressBadge.enabled": true,
  "inlineChat.enableV2": true,
  "claudeCode.preferredLocation": "panel",

  // ──────────────────────────────
  // Security / App
  // ──────────────────────────────
  "security.workspace.trust.untrustedFiles": "open",
  "application.shellEnvironmentResolutionTimeout": 30,

  // ──────────────────────────────
  // Language overrides
  // ──────────────────────────────
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
}
