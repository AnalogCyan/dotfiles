// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "context_servers": {
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {
        "github_personal_access_token": "YOUR_GITHUB_PAT",
      },
    },
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "YOUR_CONTEXT7_API_KEY",
      },
    },
  },
  "cli_default_open_behavior": "existing_window",
  "on_last_window_closed": "quit_app",
  "when_closing_with_no_tabs": "keep_window_open",
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "thinking_display": "always_collapsed",
    "expand_terminal_card": false,
    "profiles": {},
    "default_profile": "write",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
      "effort": "high",
    },
    "flexible": true,
    "dock": "left",
    "favorite_models": [
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4-6",
        "enable_thinking": true,
        "effort": "high",
      },
    ],
    "model_parameters": [],
  },
  "proxy": "",
  "git_panel": {
    "dock": "right",
    "show_count_badge": true,
    "tree_view": true,
    "file_icons": true,
  },
  "terminal": {
    "show_count_badge": false,
    "font_family": "MonaspiceKr Nerd Font Mono",
    "font_features": {
      "calt": true,
    },
    "copy_on_select": true,
    "blinking": "on",
    "cursor_shape": "bar",
  },
  "project_panel": {
    "dock": "right",
    "git_status_indicator": true,
    "diagnostic_badges": true,
  },
  "use_system_window_tabs": true,
  "bottom_dock_layout": "contained",
  "tabs": {
    "close_position": "left",
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
  },
  "status_bar": {
    "show_active_file": true,
  },
  "search": {
    "center_on_match": true,
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
  "prettier": {
    "allowed": true,
  },
  "formatter": "prettier",
  "format_on_save": "on",
  "languages": {
    "Python": {
      "formatter": "language_server",
    },
    "Zig": {
      "formatter": "language_server",
    },
    "TOML": {
      "formatter": "language_server",
    },
    "Rust": {
      "formatter": "language_server",
    },
    "Go": {
      "formatter": "language_server",
    },
  },
  "document_symbols": "on",
  "document_folding_ranges": "on",
  "semantic_tokens": "combined",
  "colorize_brackets": true,
  "code_lens": "on",
  "inlay_hints": {
    "enabled": true,
  },
  "line_ending": "enforce_lf",
  "indent_guides": {
    "coloring": "indent_aware",
    "background_coloring": "indent_aware",
  },
  "minimap": {
    "show": "auto",
  },
  "diff_view_style": "unified",
  "which_key": {
    "enabled": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "ui_font_family": "MonaspiceAr Nerd Font",
  "buffer_font_family": "MonaspiceAr Nerd Font Mono",
  "buffer_font_features": {
    "calt": true,
  },
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Colored Zed Icons Theme Dark",
  },
  "restore_on_startup": "last_session",
  "redact_private_values": true,
  "auto_install_extensions": {
    "caddyfile": true,
    "color-highlight": true,
    "colored-zed-icons-theme": true,
    "comment": true,
    "discord-presence": true,
    "dockerfile": true,
    "env": true,
    "ghostty": true,
    "git-firefly": true,
    "github-actions": true,
    "html": true,
    "ini": true,
    "make": true,
    "mcfunction": true,
    "mcp-server-context7": true,
    "mcp-server-github": true,
    "powershell": true,
    "python-requirements": true,
    "toml": true,
    "zedokai": true,
    "zig": true,
  },
  "agent_servers": {
    "kimi": {
      "type": "registry",
    },
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16.0,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "Zedokai Light (Filter Sun)",
    "dark": "Zedokai Darker (Filter Ristretto)",
  },
}
