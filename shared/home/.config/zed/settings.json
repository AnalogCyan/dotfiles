// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "git": {
    "inline_blame": {
      "show_commit_summary": false,
    },
  },
  "seed_search_query_from_cursor": "selection",
  "toolbar": {
    "code_actions": true,
  },
  "scrollbar": {
    "axes": {
      "horizontal": true,
      "vertical": true,
    },
    "show": "auto",
  },
  "sticky_scroll": {
    "enabled": true,
  },
  "autoscroll_on_clicks": false,
  "scroll_beyond_last_line": "one_page",
  "helix_mode": false,
  "buffer_line_height": "comfortable",
  "use_system_prompts": false,
  "use_system_path_prompts": false,
  "language_models": {
    "opencode": {
      "show_zen_models": false,
    },
  },
  "context_servers": {
    "mcp-server-github": {
      "enabled": true,
      "remote": false,
      "settings": {
        "github_personal_access_token": "YOUR_GITHUB_PAT",
      },
    },
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "YOUR_CONTEXT7_API_KEY",
      },
    },
    "fff": {
      "enabled": true,
      "remote": false,
      "settings": {
        "fff_binary_path": "/Users/cyan/.local/bin/fff-mcp",
        "base_path": null,
        "frecency_db": null,
        "history_db": null,
        "log_file": null,
        "log_level": "info",
        "no_update_check": false,
        "no_warmup": false,
        "max_cached_files": null,
      },
    },
  },
  "cli_default_open_behavior": "new_window",
  "on_last_window_closed": "quit_app",
  "when_closing_with_no_tabs": "keep_window_open",
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "agent": {
    "expand_edit_card": false,
    "enable_feedback": false,
    "tool_permissions": {
      "tools": {
        "create_directory": {
          "default": "allow",
        },
        "copy_path": {
          "default": "allow",
        },
        "edit_file": {
          "default": "allow",
        },
        "write_file": {
          "default": "allow",
        },
      },
      "default": "allow",
    },
    "thinking_display": "preview",
    "expand_terminal_card": false,
    "default_model": {
      "provider": "opencode",
      "model": "go/kimi-k2.5",
      "enable_thinking": false,
    },
    "flexible": true,
    "dock": "left",
    "favorite_models": [
      {
        "provider": "opencode",
        "model": "go/kimi-k2.6",
        "enable_thinking": false,
      },
      {
        "provider": "opencode",
        "model": "go/kimi-k2.5",
        "enable_thinking": false,
      },
    ],
    "model_parameters": [],
  },
  "proxy": "",
  "git_panel": {
    "dock": "right",
    "show_count_badge": true,
    "tree_view": true,
    "file_icons": true,
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "show_count_badge": false,
    "font_family": "MonaspiceKr Nerd Font Mono",
    "font_features": {
      "calt": true,
    },
    "copy_on_select": true,
    "blinking": "on",
    "cursor_shape": "bar",
  },
  "project_panel": {
    "hide_root": false,
    "bold_folder_labels": false,
    "button": true,
    "dock": "right",
    "git_status_indicator": true,
    "diagnostic_badges": true,
  },
  "use_system_window_tabs": true,
  "bottom_dock_layout": "contained",
  "tabs": {
    "show_diagnostics": "off",
    "close_position": "left",
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_menus": false,
    "show_branch_status_icon": true,
  },
  "status_bar": {
    "cursor_position_button": true,
    "show_active_file": true,
  },
  "search": {
    "center_on_match": true,
  },
  "diagnostics": {
    "button": true,
    "inline": {
      "enabled": true,
    },
  },
  "prettier": {
    "allowed": true,
  },
  "formatter": "prettier",
  "format_on_save": "on",
  "languages": {
    "Python": {
      "formatter": "language_server",
    },
    "Zig": {
      "formatter": "language_server",
    },
    "TOML": {
      "formatter": "language_server",
    },
    "Rust": {
      "formatter": "language_server",
    },
    "Go": {
      "formatter": "language_server",
    },
  },
  "document_symbols": "on",
  "document_folding_ranges": "on",
  "semantic_tokens": "combined",
  "colorize_brackets": true,
  "code_lens": "on",
  "inlay_hints": {
    "enabled": true,
  },
  "line_ending": "enforce_lf",
  "indent_guides": {
    "background_coloring": "indent_aware",
    "enabled": false,
    "coloring": "indent_aware",
  },
  "minimap": {
    "show": "auto",
    "thumb": "always",
  },
  "diff_view_style": "unified",
  "which_key": {
    "enabled": true,
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "ui_font_family": "MonaspiceAr Nerd Font",
  "buffer_font_family": "MonaspiceAr Nerd Font Mono",
  "buffer_font_features": {
    "calt": true,
  },
  "icon_theme": "Colored Zed Icons Theme Light",
  "restore_on_startup": "last_session",
  "redact_private_values": true,
  "auto_install_extensions": {
    "caddyfile": true,
    "color-highlight": true,
    "colored-zed-icons-theme": true,
    "comment": true,
    "discord-presence": true,
    "dockerfile": true,
    "env": true,
    "ghostty": true,
    "git-firefly": true,
    "github-actions": true,
    "html": true,
    "ini": true,
    "make": true,
    "mcfunction": true,
    "mcp-server-context7": true,
    "mcp-server-github": true,
    "powershell": true,
    "python-requirements": true,
    "toml": true,
    "zedokai": true,
    "zig": true,
  },
  "agent_servers": {},
  "session": {
    "trust_all_worktrees": true,
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16.0,
  "buffer_font_size": 15,
  "theme": "Zedokai Darker (Filter Ristretto)",
}
